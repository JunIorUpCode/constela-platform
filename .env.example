# ==============================================
# CONSTELA PLATFORM - Environment Variables
# ==============================================
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Constela Platform"

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/constela?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-change-in-production"
AUTH_URL="http://localhost:3000"

# Cookies
COOKIE_DOMAIN=localhost
SESSION_MAX_AGE=604800

# Realtime Server (Socket.IO)
NEXT_PUBLIC_REALTIME_URL="http://localhost:3001"
REALTIME_PORT=3001

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-access-token"
MERCADOPAGO_PUBLIC_KEY="your-mercadopago-public-key"
MERCADOPAGO_WEBHOOK_SECRET="your-mercadopago-webhook-secret"
# Sandbox (development)
MERCADOPAGO_IS_SANDBOX=true

# LiveKit
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
LIVEKIT_URL="wss://your-livekit-server.com"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-livekit-server.com"

# OpenAI (AI Assistant)
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4-turbo-preview"

# Storage (S3-compatible)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_BUCKET="constela-assets"

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Constela Platform <noreply@constela.com>"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=debug
